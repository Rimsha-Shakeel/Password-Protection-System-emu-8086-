; =====================================
; PASSWORD PROTECTION SYSTEM (OPTIMIZED)
; USER  : 5229
; ADMIN : 9999
; =====================================

.MODEL SMALL
.STACK 100H

.DATA
WELCOME   DB 10,13,10,13,' WELCOME TO PASSWORD PROTECTION SYSTEM $'
BEGIN     DB 10,13,10,13,' ENTER PASSWORD: $'

INVALID   DB 10,13,10,13,' INVALID PASSWORD! $'
WEAKMSG   DB 10,13,10,13,' PASSWORD TOO SHORT! $'

USERMSG   DB 10,13,10,13,' USER ACCESS GRANTED $'
ADMINMSG  DB 10,13,10,13,' ADMIN ACCESS GRANTED $'

LOCKMSG   DB 10,13,10,13,' SYSTEM LOCKED! WAIT 5 SECONDS $'
LOGOFF    DB 10,13,10,13,' PRESS 0 TO LOGOFF $'

ATTMSG    DB 10,13,' ATTEMPT NUMBER: $'
ATTNUM    DB '1','$'

STAR      DB '*','$'
SPACE     DB ' ', '$'
BACK      DB 08,'$'

STOPWATCH DB '5$'

INPUT     DB 10 DUP(0)
ATTEMPTS  DB 3

.CODE
START:
    MOV AX,@DATA
    MOV DS,AX

    MOV AH,09H
    LEA DX,WELCOME
    INT 21H

MAIN:
    CMP ATTEMPTS,0
    JE  LOCKED

    MOV AH,09H
    LEA DX,BEGIN
    INT 21H

    MOV BX,0

READ:
    MOV AH,07H
    INT 21H

    CMP AL,13
    JE  CHECK

    CMP AL,08
    JE  ERASE

    CMP BX,4
    JAE READ

    MOV INPUT[BX],AL
    INC BX

    MOV AH,09H
    LEA DX,STAR
    INT 21H
    JMP READ

ERASE:
    CMP BX,0
    JE READ
    DEC BX
    MOV AH,09H
    LEA DX,SPACE
    INT 21H
    MOV AH,02H
    MOV DL,08
    INT 21H
    JMP READ

CHECK:
    CMP BX,4
    JL  WEAK

    ; ---- USER PASSWORD ----
    CMP INPUT[0],'5'
    JNZ CHECK_ADMIN
    CMP INPUT[1],'2'
    JNZ CHECK_ADMIN
    CMP INPUT[2],'2'
    JNZ CHECK_ADMIN
    CMP INPUT[3],'9'
    JNZ CHECK_ADMIN

    MOV AH,09H
    LEA DX,USERMSG
    INT 21H
    JMP SUCCESS

CHECK_ADMIN:
    CMP INPUT[0],'9'
    JNZ FAILED
    CMP INPUT[1],'9'
    JNZ FAILED
    CMP INPUT[2],'9'
    JNZ FAILED
    CMP INPUT[3],'9'
    JNZ FAILED

    MOV AH,09H
    LEA DX,ADMINMSG
    INT 21H
    JMP SUCCESS

WEAK:
    MOV AH,09H
    LEA DX,WEAKMSG
    INT 21H
    JMP FAILED

FAILED:
    DEC ATTEMPTS

    MOV AH,09H
    LEA DX,INVALID
    INT 21H

    MOV AH,09H
    LEA DX,ATTMSG
    INT 21H

    MOV DL,ATTNUM
    MOV AH,02H
    INT 21H
    INC ATTNUM

    CALL DELAY
    JMP MAIN

LOCKED:
    MOV AH,09H
    LEA DX,LOCKMSG
    INT 21H

    MOV BP,0
    MOV STOPWATCH,'5'

WAITLOOP:
    MOV AH,2CH
    INT 21H
    MOV BH,DH

WAITSEC:
    MOV AH,2CH
    INT 21H
    CMP BH,DH
    JE WAITSEC

    MOV AH,09H
    LEA DX,STOPWATCH
    INT 21H
    MOV AH,09H
    LEA DX,BACK
    INT 21H

    SUB STOPWATCH,1
    INC BP
    CMP BP,5
    JL WAITLOOP

    MOV ATTEMPTS,3
    MOV ATTNUM,'1'
    JMP MAIN

SUCCESS:
    CALL DELAY
    MOV AH,09H
    LEA DX,LOGOFF
    INT 21H

LOGOUT:
    MOV AH,07H
    INT 21H
    CMP AL,'0'
    JNZ LOGOUT

    MOV AH,4CH
    INT 21H

; -------- Optimized Delay --------
DELAY:
    MOV CX,2000H     ; reduced delay
D1:
    LOOP D1
    RET

END START
